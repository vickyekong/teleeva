# Supabase (required for full-stack auth and database)
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: for server-side admin operations (do not expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (for Eva / AI diagnosis)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Optional: existing API base URL if you use a separate backend
# NEXT_PUBLIC_API_URL=https://api.example.com
